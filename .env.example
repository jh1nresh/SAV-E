# Wanderly iOS - Environment Variables
# Copy this file to .env and fill in your values

# Gemini API (for AI parsing)
GEMINI_API_KEY=AIzaxxxxx

# Google Places API (for place matching & details)
GOOGLE_PLACES_API_KEY=AIzaxxxxx

# Mobile backend
WANDERLY_API_URL=https://your-wanderly-api.up.railway.app

# Railway backend secrets (server-side only; never ship in app)
DATABASE_URL=postgresql://postgres:password@host:port/railway
PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----..."

# Privy (authentication)
PRIVY_APP_ID=clxxxxx
PRIVY_APP_CLIENT_ID=clxxxxx
