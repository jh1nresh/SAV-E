# SAV-E backend environment variables (names only — set real values in Railway).

# --- Sendblue iMessage bot (spike) ---
# POST /v0/sendblue/webhook fetches a texted link's caption, extracts the venue
# via Gemini, and replies via the Sendblue API.
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET=
# Optional: if set, inbound webhooks are HMAC-verified. Skip for the spike.
SENDBLUE_SIGNING_SECRET=

# --- Gemini (venue extraction; already used elsewhere in the backend) ---
GEMINI_API_KEY=
# Or, alternatively:
GOOGLE_GEMINI_API_KEY=
# Optional model override:
SAVE_MAAT_GEMINI_MODEL=
