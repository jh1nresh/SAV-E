{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd wanderly-rn && npm install",
  "buildCommand": "cd wanderly-rn && npm run export:web",
  "outputDirectory": "wanderly-rn/dist",
  "framework": null,
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
